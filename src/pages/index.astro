---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Headless Platform Showcase" description="High-performance Astro + React engineering portfolio and platform demo">
  <section class="container" style="padding-block: var(--space-16);">
    <h1 class="heading-1">Headless Platform Showcase</h1>
    <p class="body-large text-secondary">
      Engineering portfolio and platform demo with GitHub API integration, analytics, and scalable frontend patterns.
    </p>
    <a href="/projects" class="btn btn-primary" style="margin-top: var(--space-4);">View Projects</a>
  </section>
</BaseLayout>
